# BMS Blood Stock - Server Configuration
# Copy this file to .env and fill in your values

# Server port (default: 7712)
PORT=7712

# PostgreSQL default connection (optional)
# If set, client can use API-only mode (only needs API Endpoint)
# If not set, client must provide all DB credentials
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=hosxp_db
DB_USER=postgres
DB_PASSWORD=your_password_here
